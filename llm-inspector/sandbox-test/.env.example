# LLM Inspector — Environment Variables
# Copy to .env and edit before running

# ── Application ────────────────────────────────────────────────
APP_ENV=development          # development | production
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Database ───────────────────────────────────────────────────
# SQLite (default, zero-config)
DATABASE_URL=sqlite:///./llm_inspector.db

# PostgreSQL (when available)
# DATABASE_URL=postgresql+asyncpg://inspector:inspector@localhost:5432/llm_inspector

# ── Security ───────────────────────────────────────────────────
# 32-byte base64 AES key for API key encryption.
# Generate with:
#   python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Leave blank in development — a deterministic dev key will be used automatically.
# REQUIRED in production.
ENCRYPTION_KEY=

# Hours after task completion before the stored API key is wiped
API_KEY_TTL_HOURS=72

# ── Request behaviour ──────────────────────────────────────────
DEFAULT_REQUEST_TIMEOUT_SEC=60
MAX_STREAM_CHUNKS=512
# Milliseconds between test case requests (rate-limit protection)
INTER_REQUEST_DELAY_MS=500

# ── Data retention ─────────────────────────────────────────────
RAW_RESPONSE_TTL_DAYS=7
STREAM_CHUNKS_TTL_DAYS=3

# ── Task backend ───────────────────────────────────────────────
# Set to true only when Redis + Celery are available
USE_CELERY=false
REDIS_URL=redis://localhost:6379/0

# ── Pre-detection ──────────────────────────────────────────────
# Minimum cosine similarity confidence to stop pre-detection early
PREDETECT_CONFIDENCE_THRESHOLD=0.85
